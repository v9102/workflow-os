# Azure OpenAI
AZURE_OPENAI_API_KEY=your-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-02-15-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Cosmos DB
COSMOS_DB_CONNECTION_STRING=AccountEndpoint=https://your-cosmos.documents.azure.com:443/;AccountKey=your-key;Database=workflowos
COSMOS_DB_DATABASE=workflowos
COSMOS_DB_CONTAINER=sessions

# Service Bus
SERVICEBUS_CONNECTION_STRING=Endpoint=sb://your-namespace.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=your-key
SERVICEBUS_QUEUE_NAME=feedback

# Redis Cache
REDIS_URL=redis://localhost:6379/0

# Microsoft 365 (Planner, Teams, Outlook calendar export)
MICROSOFT_CLIENT_ID=your-client-id
MICROSOFT_CLIENT_SECRET=your-client-secret
MICROSOFT_TENANT_ID=your-tenant-id
MICROSOFT_REDIRECT_URI=http://localhost:3000/auth/callback
# Target mailbox (UPN or object id) for Outlook calendar events under app-only auth
MICROSOFT_DEFAULT_USER_ID=

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Webhooks
WEBHOOK_URL=
WEBHOOK_SECRET=

# Audit
AUDIT_LOG_FILE=audit.log

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Logging
LOG_LEVEL=INFO
